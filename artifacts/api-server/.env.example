# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Server Port
PORT=8080

# Optional: Database URL (if not set, uses in-memory PGlite)
# DATABASE_URL=postgresql://user:password@localhost:5432/wanis

# Optional: Replit Environment Detection
# REPLIT_ENV=true
